@section scripts {

    <script>
        $(function () {
            $(document).keyup(function (e) {
                console.log(e.keyCode);
                if (e.keyCode == 13) {
                    alert('ssd');
                }

                if (e.keyCode == 81) {
                    alert('ssaaaaad');
                }
            });
        });
    </script>
}